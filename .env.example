# One Router Configuration
#
# Only 5 environment variables needed. All other config lives in the database.

# Storage backend (scheme selects backend):
#   sqlite://./data/gateway.db   — SQLite (default, zero-config)
#   postgres://user:pass@host/db — PostgreSQL
#   dynamodb://us-east-1         — DynamoDB (uses AWS default credentials)
DATABASE=sqlite://./data/gateway.db

# HTTP listen port (default: 8000)
PORT=8000

# Log level: trace, debug, info, warn, error (default: info)
LOG_LEVEL=info

# Master API key for admin access (optional, bypasses rate limits)
# MASTER_API_KEY=sk-master-your-secret-key

# AES-256-GCM encryption key for backend credentials (optional)
# If not set, credentials are stored in plaintext with a startup warning.
# ENCRYPTION_KEY=your-32-char-encryption-key-here
